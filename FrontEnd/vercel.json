{
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/Index.html"
    },
    {
      "source": "/index.html",
      "destination": "/Index.html"
    },
    {
      "source": "/Css/:path*",
      "destination": "/Css/:path*"
    },
    {
      "source": "/Js/:path*",
      "destination": "/Js/:path*"
    },
    {
      "source": "/Img/:path*",
      "destination": "/Img/:path*"
    },
    {
      "source": "/Html/:path*",
      "destination": "/Html/:path*"
    },
    {
      "source": "/frontend",
      "destination": "/Index.html"
    },
    {
      "source": "/frontend/",
      "destination": "/Index.html"
    },
    {
      "source": "/frontend/silenciadores",
      "destination": "/Html/Silenciadores.html"
    },
    {
      "source": "/frontend/catalizadores",
      "destination": "/Html/Catalizadores.html"
    },
    {
      "source": "/frontend/flexibles",
      "destination": "/Html/Flexibles.html"
    },
    {
      "source": "/frontend/accesorios",
      "destination": "/Html/Accesorios.html"
    },
    {
      "source": "/frontend/extras",
      "destination": "/Html/Extras.html"
    },
    {
      "source": "/silenciadores",
      "destination": "/Html/Silenciadores.html"
    },
    {
      "source": "/catalizadores",
      "destination": "/Html/Catalizadores.html"
    },
    {
      "source": "/flexibles",
      "destination": "/Html/Flexibles.html"
    },
    {
      "source": "/accesorios",
      "destination": "/Html/Accesorios.html"
    },
    {
      "source": "/extras",
      "destination": "/Html/Extras.html"
    }
  ]
}
